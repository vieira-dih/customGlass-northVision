# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# Host do servidor PostgreSQL
DB_HOST=localhost

# Porta do PostgreSQL (padrão: 5432)
DB_PORT=5432

# Nome do banco de dados
DB_NAME=custom_glass_db

# Usuário do PostgreSQL
DB_USER=postgres

# Senha do usuário PostgreSQL
DB_PASSWORD=sua_senha_aqui

# ==========================================
# NUVEMSHOP OAUTH CONFIGURATION
# ==========================================
# ID da aplicação no Nuvemshop
# Obter em: https://www.nuvemshop.com.br/admin/apps
NUVEMSHOP_CLIENT_ID=seu_client_id_aqui

# Secret da aplicação no Nuvemshop (NUNCA compartilhar!)
# Obter em: https://www.nuvemshop.com.br/admin/apps
NUVEMSHOP_CLIENT_SECRET=seu_client_secret_aqui

# URL para onde Nuvemshop redireciona após autorizar
# DEVE estar registrado no painel da Nuvemshop em "URLs"
NUVEMSHOP_REDIRECT_URI=http://localhost:3000/auth/callback

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Chave secreta para assinar JWT (gerar algo seguro!)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_super_segura_aqui

# ==========================================
# SERVER CONFIGURATION
# ==========================================
# Porta que o backend vai rodar
PORT=3000

# Ambiente (development, production, etc)
NODE_ENV=development

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# URL do frontend (para redirects do OAuth)
FRONTEND_URL=http://localhost:5173
